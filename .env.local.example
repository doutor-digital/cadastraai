# URL of the .NET backend (CadastraAI.API). Default dev profile listens on http://localhost:5299
NEXT_PUBLIC_API_URL=

# Google OAuth client ID used by the Google Identity Services button on /login, /cadastro
# and /aceitar-convite/[token]. Get one at https://console.cloud.google.com/apis/credentials
# (type: Web application, add http://localhost:3000 as an authorized JavaScript origin).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
